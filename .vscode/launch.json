{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: runserver",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": [
        "runserver"
      ],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings"
      }
    },
    {
      "name": "Browser Windows",
      "runtimeExecutable": "C:\\chrome-win\\chrome.exe",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}/premises_mfareset",
      "disableNetworkCache": true
    },
    {
      "name": "Browser Ubuntu",
      "type": "chrome",
      "request": "launch",
      "runtimeExecutable": "/usr/bin/google-chrome",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}/premises_mfareset"
    },
    {
      "name": "Run Test Script",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": [
        "runscript",
        "test_script",
        "--script-args",
        "testtes@dtu.dk"
      ],
      "django": true,
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Start Server and Browser (Windows)",
      "configurations": [
        "Django: runserver",
        "Browser Windows"
      ]
    },
    {
      "name": "Start Server and Browser (Ubuntu)",
      "configurations": [
        "Django: runserver",
        "Browser Ubuntu"
      ]
    }
  ]
}